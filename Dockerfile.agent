FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    python3 \
    python3-pip \
    python3-venv \
    build-essential \
    ca-certificates \
    curl \
    jq \
  && rm -rf /var/lib/apt/lists/*

# Install the agent code
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --omit=dev
COPY dist/ ./dist/

# Project output directory — mount a host volume here
RUN mkdir -p /workspace
WORKDIR /workspace

# The container runs a single agent query via stdin/stdout JSON protocol.
# sandbox.ts spawns this with: docker run ... agent-sandbox <json-request>
ENTRYPOINT ["node", "/app/dist/run.js"]
