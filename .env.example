ANTHROPIC_API_KEY=sk-ant-your-key-here
AGENT_OUTPUT_DIR=./projects
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_TURNS=50
AGENT_WEB_PORT=3333

# Bearer token required for HTTP API auth. Generate with: openssl rand -hex 32
# (Server refuses to start if unset. DO NOT ship or commit a real token.)
AGENT_API_TOKEN=REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32

# CORS origin for HTTP API. Set to your client's origin in production.
# Use "*" to allow any origin (NOT recommended for production — server warns at startup).
AGENT_CORS_ORIGIN=http://localhost:3333

# Max requests per minute per IP on POST /agent (sliding window, in-memory)
AGENT_RATE_LIMIT=10
# Max distinct IPs tracked by the rate limiter (LRU-evicted at the cap).
AGENT_RATE_LIMIT_MAX_IPS=10000
# Only set to "true" behind a trusted reverse proxy (rate-limit by the
# rightmost X-Forwarded-For hop instead of the socket address).
AGENT_TRUST_PROXY=false
# Hard cap (bytes) on the POST /agent request body — oversized requests get 413.
AGENT_MAX_BODY_BYTES=1000000

# Audit log (JSON lines in ./logs/audit.log). Set to "false" to disable.
AGENT_AUDIT_LOG=true

# Encrypt session files at rest (bracket encryption — encrypted while Dom is idle,
# decrypted during active runs). Key is derived from AGENT_API_TOKEN via PBKDF2.
# Requires AGENT_API_TOKEN to be set.
AGENT_SESSION_ENCRYPT=false
# One-time migration opt-in: set to "true" only when first enabling encryption
# on a directory that already holds PLAINTEXT sessions. Otherwise plaintext at
# rest is rejected as a downgrade/tamper. Unset it again after the first run.
AGENT_SESSION_ENCRYPT_MIGRATE=false

# Per-session cost cap (USD). Leave empty for no cap. When exceeded, the next
# run on that session is refused with a 402 response (HTTP) or BudgetExceededError (CLI).
AGENT_MAX_COST_USD=

# Shared brain — Dom's curated long-term memory (markdown files).
# AGENT_BRAIN_DIR defaults to ./.dom-brain (created on first run).
# MAX_LOADED caps how many entries get injected into the system prompt per run.
# MAX_ENTRIES is the hard cap on total entries; curator must evict before adding.
AGENT_BRAIN_DIR=./.dom-brain
AGENT_BRAIN_MAX_LOADED=30
AGENT_BRAIN_MAX_ENTRIES=100

# TLS (optional). Set BOTH to serve HTTPS; leave BOTH empty for HTTP.
# Generate a self-signed dev cert with:
#   openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes
AGENT_TLS_CERT=
AGENT_TLS_KEY=

# Docker sandbox (set to "false" to run locally without Docker)
AGENT_SANDBOX=true
AGENT_DOCKER_IMAGE=dom-sandbox

# Where the SDK stores session files. Auto-defaults to ./.dom-claude/ (inside
# the project, NOT in ~/.claude/). Uncomment to override.
# CLAUDE_CONFIG_DIR=./.dom-claude

# Additional allowed network hosts (comma-separated).
# By default Dom allows package registries + GitHub. Add more here if needed.
ALLOWED_HOSTS=

# Optional egress proxy for the sandbox container. When set (e.g. the HAProxy
# stack in docker-compose.egress.yml), HTTPS_PROXY/HTTP_PROXY are injected into
# the container. NOTE: opt-in and currently UNVERIFIED — see CLAUDE.md.
AGENT_EGRESS_PROXY=
